// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  storageProviders StorageProvider[]
  uploads          Upload[]
  magicLinks       MagicLink[]

  @@map("users")
}

model MagicLink {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@map("magic_links")
}

enum ProviderType {
  GOOGLE_DRIVE
  ONEDRIVE
  LOCAL
}

model StorageProvider {
  id           String       @id @default(uuid())
  userId       String
  type         ProviderType
  accessToken  String?      @db.Text
  refreshToken String?      @db.Text
  expiresAt    DateTime?
  isActive     Boolean      @default(true)
  metadata     Json?        // For additional provider-specific data
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  // Relations
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  uploads Upload[]

  @@unique([userId, type])
  @@index([userId])
  @@map("storage_providers")
}

enum UploadStatus {
  PENDING
  UPLOADING
  COMPLETED
  FAILED
  CANCELLED
}

model Upload {
  id                String        @id @default(uuid())
  userId            String
  providerId        String
  status            UploadStatus  @default(PENDING)
  totalFiles        Int           @default(0)
  completedFiles    Int           @default(0)
  failedFiles       Int           @default(0)
  totalBytes        BigInt        @default(0)
  uploadedBytes     BigInt        @default(0)
  progress          Float         @default(0) // Percentage 0-100
  errorMessage      String?       @db.Text
  metadata          Json?         // Additional upload metadata
  startedAt         DateTime?
  completedAt       DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  // Relations
  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider StorageProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  files    File[]

  @@index([userId])
  @@index([providerId])
  @@index([status])
  @@map("uploads")
}

enum FileStatus {
  PENDING
  UPLOADING
  COMPLETED
  FAILED
  CANCELLED
}

model File {
  id              String     @id @default(uuid())
  uploadId        String
  name            String
  originalPath    String     @db.Text // Path on user's system
  remotePath      String?    @db.Text // Path on storage provider
  remoteId        String?    // Provider-specific file ID
  size            BigInt
  mimeType        String?
  status          FileStatus @default(PENDING)
  progress        Float      @default(0) // Percentage 0-100
  uploadedBytes   BigInt     @default(0)
  errorMessage    String?    @db.Text
  retryCount      Int        @default(0)
  metadata        Json?      // Additional file metadata (checksums, etc)
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  // Relations
  upload Upload @relation(fields: [uploadId], references: [id], onDelete: Cascade)

  @@index([uploadId])
  @@index([status])
  @@map("files")
}

enum JobStatus {
  WAITING
  ACTIVE
  COMPLETED
  FAILED
  DELAYED
  PAUSED
}

model QueueJob {
  id          String    @id @default(uuid())
  jobId       String    @unique // BullMQ job ID
  queueName   String
  jobData     Json
  status      JobStatus @default(WAITING)
  progress    Float     @default(0)
  attempts    Int       @default(0)
  result      Json?
  error       String?   @db.Text
  processedAt DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([queueName])
  @@index([status])
  @@map("queue_jobs")
}
